{
  "name": "side-business",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A prompt optimization web app with instant heuristic analysis and secure OpenRouter-powered rewriting.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build && node -e \"require('fs').copyFileSync('_worker.js','dist/_worker.js')\"",
    "preview": "vite preview",
    "deploy": "npm run build:pages && wrangler pages deploy dist",
    "preview:wrangler": "npm run build && wrangler dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lido772/promptlab.git"
  },
  "keywords": [
    "prompt",
    "ai",
    "tailwind",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lido772/promptlab/issues"
  },
  "homepage": "https://github.com/lido772/promptlab#readme",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.27.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.6",
    "vite": "^6.1.0",
    "wrangler": "^4.72.0"
  }
}
