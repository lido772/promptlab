{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "promptup",
  "main": "_worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "promptup.cloud/*",
      "zone_name": "promptup.cloud"
    }
  ],
  "build": {
    "command": "npm run build"
  }
}